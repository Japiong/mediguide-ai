# ==========================
# MediGuide AI — .env.example
# Copy this file to .env and fill in your values
# ==========================

# ── Server ──────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Database ─────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL=postgresql://username:password@localhost:5432/mediguide_ai

# ── AI Provider ──────────────────────────────────
# Use GitHub inference with a token from GitHub
GITHUB_TOKEN=your_github_inference_token_here
# Optional: override GitHub inference endpoint or model
# GITHUB_ENDPOINT=https://models.github.ai/inference
# GITHUB_MODEL=gpt-4o

# ── Frontend ─────────────────────────────────────
# URL of the backend API (used by Next.js rewrite)
NEXT_PUBLIC_API_URL=http://localhost:5000

# URL of the frontend (used by CORS in server)
CLIENT_URL=http://localhost:3000

# ── Auth (Optional - for future JWT support) ─────
# JWT_SECRET=your_super_secret_jwt_key_min_32_chars
# JWT_EXPIRES_IN=7d

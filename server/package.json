{
  "name": "mediguide-ai-server",
  "version": "1.0.0",
  "description": "MediGuide AI Backend API",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "test": "jest --testEnvironment=node",
